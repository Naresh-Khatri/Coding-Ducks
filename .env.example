# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# The database URL is used to connect to your database.
POSTGRES_URL=""

# Redis — required for realtime ducklet membership updates
# (access requests / invites / role changes / visibility flips).
# Both the Next.js API and the Hocuspocus server read this. If unset,
# membership changes still persist but won't propagate in realtime.
REDIS_URL=''

# Better Auth
# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=''

# GitHub OAuth
BETTER_AUTH_GITHUB_ID=""
BETTER_AUTH_GITHUB_SECRET=""

# Google OAuth
BETTER_AUTH_GOOGLE_ID=".com"
BETTER_AUTH_GOOGLE_SECRET=""

# URLs
BASE_URL="http://localhost:3000"
PRODUCTION_URL="https://example.com"

# Hocuspocus realtime server (collaborative ducklet editing)
NEXT_PUBLIC_SOCKET_URL="http://localhost:5000"
# Comma-separated WebSocket origin allowlist. Leave empty to allow all (dev).
# In production set to e.g. "https://app.example.com,https://example.com".
ALLOWED_WS_ORIGINS=""

# Umami analytics (optional). Leave both empty to disable — the script
# tag is only injected when both values are set.
# Cloud example: NEXT_PUBLIC_UMAMI_SRC="https://cloud.umami.is/script.js"
NEXT_PUBLIC_UMAMI_SRC=""
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""